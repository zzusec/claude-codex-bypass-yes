{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf /Users/*)",
      "Bash(mkfs *)",
      "Bash(dd if=* of=/dev/*)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 /Users/YOUR_USERNAME/.claude/hooks/danger-guard.py"
          }
        ]
      }
    ]
  }
}
